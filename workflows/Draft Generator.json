    {
      "parameters": {
        "jsCode": "const draft = $json.originalDraft;\n\nconst evaluationPrompt = `\nYou are a senior technical editor.\n\nEvaluate the following newsletter draft on a scale of 1 to 10.\n\nCriteria:\n- Clarity\n- Insight depth\n- Professional tone\n- Non-generic writing\n- Actionability\n\nReturn STRICT JSON only:\n\n{\n  \"score\": number,\n  \"feedback\": \"short explanation\"\n}\n\nNewsletter draft:\n${draft}\n`;\n\nreturn [{\n  json: {\n    prompt: evaluationPrompt,\n    originalDraft: draft\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [912, -240],
      "id": "e43f096e-b00e-497f-b463-078a13942024",
      "name": "Code in JavaScript3"
    },
