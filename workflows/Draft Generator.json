      "typeVersion": 2.3,
      "position": [1200, 368],
      "id": "bafcfca4-a37f-44c0-b430-faed76e5a95c",
      "name": "If"
    },
    {
      "parameters": {
        "jsCode": "// 1. Get the raw response and clean up special characters\nlet raw = $input.first().json.response || \"\";\n\n// Remove markdown blocks and normalize whitespace/newlines\nraw = raw.replace(/```json/g, \"\")\n         .replace(/```/g, \"\")\n         .replace(/\\n/g, \" \") \n         .trim();\n\nlet evaluation = { score: 0, feedback: \"Parsing failed\" };\n\ntry {\n  evaluation = JSON.parse(raw);\n} catch (e) {\n  // Regex fallback if JSON is still malformed\n  const scoreMatch = raw.match(/\"score\":\\s*(\\d+)/);\n  if (scoreMatch) {\n    evaluation.score = parseInt(scoreMatch[1]);\n    evaluation.feedback = \"Extracted via fallback (JSON format error)\";\n  }\n}\n\n// 2. Safely grab the original draft from the input\nconst originalDraft = $input.first().json.originalDraft || \"\";\n\nreturn [{\n  json: {\n    approved: (evaluation.score || 0) >= 8,\n    score: evaluation.score || 0,\n    feedback: evaluation.feedback || \"Review required\",\n    originalDraft: originalDraft,\n    retryCount: 0\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 288],
      "id": "d8761a72-f03a-43fb-9e5b-e6f65d2eb8fe",
      "name": "Parse Evaluation"
    },
    {
      "parameters": {
        "jsCode": "const draft = $json.originalDraft;\nconst feedback = $json.feedback;\n\nconst refinePrompt = `\nYou are a senior technical editor.\n\nImprove the following newsletter based on this feedback:\n\nFeedback:\n${feedback}\n\nOriginal Draft:\n${draft}\n\nMake it sharper, more insight-driven, and less generic.\nReturn ONLY improved HTML.\n`;\n\nreturn [{\n  json: {\n    prompt: refinePrompt\n  }\n}];"
      },
