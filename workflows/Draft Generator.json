    {
      "parameters": {
        "jsCode": "// Grab the HTML directly from your template node to be safe\nconst html = $node[\"Code in JavaScript1\"].json.html || \"\";\n\nconst plainText = html\n  .replace(/<h1>/g, \"*\")\n  .replace(/<\\/h1>/g, \"*\\n\")\n  .replace(/<h2>/g, \"\\n\\n*\")\n  .replace(/<\\/h2>/g, \"*\\n\")\n  .replace(/<[^>]+>/g, \"\")\n  .substring(0, 1200);\n\n// Fallback message if something goes wrong\nconst finalMessage = plainText.trim().length > 0 ? plainText : \"Newsletter draft generated but preview is unavailable.\";\n\nreturn [{\n  json: {\n    text: \"Frontend Weekly Draft\",\n    blocks: [\n      {\n        type: \"section\",\n        text: {\n          type: \"mrkdwn\",\n          text: finalMessage\n        }\n      }\n    ]\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
