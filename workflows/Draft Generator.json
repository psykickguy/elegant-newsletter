    {
      "parameters": {
        "jsCode": "const aiContent = $input.first().json.finalDraft;\n\n// Style injected content\nconst styledContent = aiContent\n  .replace(/<h2>/g, '<h2 style=\"margin:30px 0 10px 0;font-size:20px;\">')\n  .replace(/<p>/g, '<p style=\"color:#444;line-height:1.6;margin:10px 0;\">')\n  .replace(/<a /g, '<a style=\"color:#F26C2E;text-decoration:none;font-weight:bold;\" ');\n\nconst template = `\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f5f5f5;\">\n<tr>\n<td align=\"center\">\n<table width=\"600\" cellpadding=\"20\" cellspacing=\"0\" style=\"background:#ffffff;font-family:Arial,sans-serif;\">\n\n<tr>\n<td style=\"background:#F26C2E;height:6px;padding:0;\"></td>\n</tr>\n\n\n\n<tr>\n<td>\n${styledContent}\n</td>\n</tr>\n\n<tr>\n<td align=\"center\">\n<a href=\"https://elegantfrontend.training\"\nstyle=\"display:inline-block;padding:12px 20px;background:#F26C2E;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:bold;\">\nExplore More on Elegant Frontend\n</a>\n</td>\n</tr>\n\n<tr>\n<td style=\"font-size:12px;color:#888;text-align:center;\">\nYou're receiving this because you subscribed at elegantfrontend.training\n</td>\n</tr>\n\n</table>\n</td>\n</tr>\n</table>\n`;\n\nreturn [{ json: { html: template } }];"
      },
